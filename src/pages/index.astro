---
import BaseLayout from "../layouts/BaseLayout.astro";
import GradientBlob from "../components/GradientBlob.astro";
import IsoCube from "../components/IsoCube.astro";
import SocialLinks from "../components/SocialLinks.astro";
---

<BaseLayout title="Olli Jokinen — Home">
  <section class="relative flex min-h-[calc(100vh-4rem)] flex-col items-center justify-center px-6 overflow-hidden">
    <!-- Isometric grid background -->
    <div class="absolute inset-0 iso-grid opacity-40" aria-hidden="true" />

    <!-- Soft blobs -->
    <GradientBlob class="animate-float -top-32 -left-32 h-80 w-80" />
    <GradientBlob class="animate-float-delayed -bottom-32 -right-32 h-96 w-96" />
    <GradientBlob class="animate-float-slow top-1/4 right-10 h-48 w-48" />

    <!-- Floating isometric cubes -->
    <div class="absolute top-20 left-[10%] animate-float iso-scene" aria-hidden="true">
      <IsoCube size={40} />
    </div>
    <div class="absolute top-40 right-[15%] animate-float-delayed iso-scene" aria-hidden="true">
      <IsoCube size={55} />
    </div>
    <div class="absolute bottom-32 left-[20%] animate-float-slow iso-scene" aria-hidden="true">
      <IsoCube size={35} />
    </div>
    <div class="absolute bottom-20 right-[25%] animate-float iso-scene hidden md:block" aria-hidden="true">
      <IsoCube size={45} />
    </div>
    <div class="absolute top-[60%] left-[5%] animate-float-delayed iso-scene hidden md:block" aria-hidden="true">
      <IsoCube size={28} />
    </div>

    <!-- Content -->
    <div class="relative z-10 flex max-w-2xl flex-col items-center text-center">
      <!-- Isometric avatar -->
      <div class="mb-8 iso-scene">
        <div class="iso-cube w-24 h-24 animate-bounce-gentle">
          <div class="iso-face-top absolute w-24 h-24" style="transform: translateZ(48px);">
            <div class="flex h-full w-full items-center justify-center">
              <span class="font-display text-2xl font-bold text-iso-700" style="transform: rotateZ(45deg) rotateX(0deg);">OJ</span>
            </div>
          </div>
          <div class="iso-face-left absolute w-24 h-24 origin-bottom" style="transform: rotateX(-90deg) translateZ(48px);" />
          <div class="iso-face-right absolute w-24 h-24 origin-right" style="transform: rotateY(90deg) translateZ(48px);" />
        </div>
      </div>

      <!-- Name -->
      <h1 class="font-display text-4xl font-bold tracking-tight text-iso-800 sm:text-5xl md:text-6xl mt-16">
        Olli Jokinen
      </h1>
      <div class="mt-2 h-1.5 w-24 rounded-full bg-gradient-to-r from-iso-400 via-iso-500 to-iso-600 iso-shadow" />

      <!-- Bio -->
      <p class="mt-8 max-w-lg text-lg leading-relaxed text-slate-500">
        Developer and engineer scaling European startups into global products.
        I build across the full stack — from data platforms and AI-driven
        applications to LLM fine-tuning and frontend. Recognized by Deloitte
        Tech Fast 50 and the Google Cloud Customer Award.
      </p>

      <!-- Social links -->
      <div class="mt-10">
        <SocialLinks />
      </div>
    </div>

    <!-- Career Timeline -->
    <div class="relative z-10 mt-24 w-full max-w-2xl px-4">
      <h2 class="font-display text-2xl font-bold text-iso-800 text-center mb-12">Career</h2>
      <div class="relative">
        <!-- Vertical line -->
        <div class="absolute left-4 md:left-1/2 top-0 bottom-0 w-0.5 bg-iso-200 -translate-x-1/2" aria-hidden="true" />

        {[
          { year: "2025 —", role: "Founding Engineer", company: "Zero.inc", description: "Building the next generation of autonomous GTM." },
          { year: "2024 — 2025", role: "Lead Data Engineer", company: "RELEX Solutions", description: "Designing and implementing data platforms and data products at scale." },
          { year: "2020 — 2024", role: "Data Scientist → Senior Engineer & Cloud Architect", company: "Snowfox.AI", description: "Scaled revenue 15x from 0.2M to 3M. #3 developer, #7 employee." },
          { year: "2014 — 2020", role: "Developer & Data Scientist", company: "Self-Employed", description: "Freelance consulting, web development, and data science for startups." },
        ].map((item, i) => (
          <div class:list={["relative flex items-start mb-8 last:mb-0", i % 2 === 0 ? "md:flex-row-reverse" : ""]}>
            <!-- Dot -->
            <div class="absolute left-4 md:left-1/2 w-3 h-3 bg-iso-500 rounded-sm rotate-45 -translate-x-1/2 mt-1.5 z-10 border-2 border-white" />

            <!-- Card -->
            <div class:list={["ml-10 md:ml-0 md:w-[calc(50%-2rem)]", i % 2 === 0 ? "md:mr-auto md:pr-0 md:pl-0" : "md:ml-auto"]}>
              <div class="bg-white border-2 border-iso-200 rounded-xl p-5 iso-shadow">
                <span class="text-xs font-semibold uppercase tracking-wider text-iso-500">{item.year}</span>
                <h3 class="mt-1 font-display text-lg font-semibold text-slate-800">{item.role}</h3>
                <p class="text-sm font-medium text-iso-600">{item.company}</p>
                <p class="mt-2 text-sm text-slate-500">{item.description}</p>
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>

    <!-- Isometric decorative row at bottom -->
    <div class="absolute bottom-0 left-0 right-0 h-32 overflow-hidden" aria-hidden="true">
      <div class="iso-scene flex items-end justify-center gap-1 h-full pb-4 opacity-20">
        {Array.from({ length: 12 }).map((_, i) => (
          <div
            class="bg-iso-400 rounded-sm"
            style={`width: 40px; height: ${20 + Math.sin(i * 0.8) * 40 + 40}px; transform: skewX(-20deg); opacity: ${0.3 + (i % 3) * 0.2};`}
          />
        ))}
      </div>
    </div>
  </section>
</BaseLayout>
