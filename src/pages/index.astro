---
import BaseLayout from "../layouts/BaseLayout.astro";
import ParticleNetwork from "../components/ParticleNetwork.astro";
import SocialLinks from "../components/SocialLinks.astro";
---

<BaseLayout title="Olli Jokinen — Home">
  <!-- Hero -->
  <section class="relative flex min-h-[calc(100vh-4rem)] flex-col items-center justify-center px-6 overflow-hidden">
    <div class="absolute inset-0 studio-grid" aria-hidden="true" />
    <ParticleNetwork />

    <div class="relative z-10 flex max-w-2xl flex-col items-center text-center">
      <span class="annotation mb-4">// engineer &middot; architect &middot; builder</span>

      <h1 class="font-display text-5xl font-bold tracking-tight text-studio-50 sm:text-6xl md:text-7xl">
        Olli Jokinen
      </h1>

      <p class="mt-3 font-mono text-sm text-studio-400 tracking-wide">
        Not the one with the hockey stick.
      </p>

      <div class="mt-1 h-px w-32 bg-gradient-to-r from-transparent via-accent-blue to-transparent glow-line" />

      <p class="mt-8 max-w-lg text-base leading-relaxed text-studio-300">
        Developer and engineer scaling European startups into global products.
        I build across the full stack — from data platforms and AI-driven
        applications to LLM fine-tuning and frontend. Recognized by Deloitte
        Tech Fast 50 and the Google Cloud Customer Award.
      </p>

      <div class="mt-10">
        <SocialLinks />
      </div>
    </div>
  </section>

  <!-- Stack layers -->
  <section class="relative px-6 py-24 overflow-hidden">
    <div class="absolute inset-0 studio-grid opacity-50" aria-hidden="true" />

    <div class="relative z-10 mx-auto max-w-3xl">
      <!-- Section label -->
      <div class="flex items-center gap-3 mb-12">
        <span class="annotation">career.stack</span>
        <div class="flex-1 h-px bg-accent-blue/10" />
      </div>

      <!-- Timeline as layers/tracks -->
      <div class="flex flex-col gap-4">
        {[
          { year: "2025 —", role: "Founding Engineer", company: "Zero.inc", description: "Building the next generation of autonomous GTM.", color: "accent-blue" },
          { year: "2024 — 2025", role: "Lead Data Engineer", company: "RELEX Solutions", description: "Designing and implementing data platforms and data products at scale.", color: "accent-cyan" },
          { year: "2020 — 2024", role: "Senior Data Engineer, Cloud Architect & Onboarding Tech Lead", company: "Snowfox.AI", description: "Scaled revenue 15x from 0.2M to 3M. #3 developer, #7 employee. Google Cloud Customer Award 2023, Deloitte Tech Fast 50 (2024 & 2025).", color: "accent-amber" },
          { year: "2014 — 2020", role: "Developer & Data Scientist", company: "Self-Employed", description: "Freelance consulting, web development, and data science for startups.", color: "accent-green" },
        ].map((item) => (
          <div class="track-card rounded-lg p-5 group">
            <div class="flex items-start gap-4">
              <!-- Track indicator -->
              <div class="flex flex-col items-center gap-1 pt-1">
                <div class={`w-2 h-2 rounded-full bg-${item.color}`} />
                <div class={`w-px h-full bg-${item.color}/20`} />
              </div>

              <div class="flex-1 min-w-0">
                <div class="flex items-baseline justify-between gap-2 flex-wrap">
                  <h3 class="font-display text-base font-semibold text-studio-100 group-hover:text-accent-blue transition-colors">{item.role}</h3>
                  <span class="font-mono text-xs text-studio-500">{item.year}</span>
                </div>
                <p class={`font-mono text-xs text-${item.color} mt-0.5`}>{item.company}</p>
                <p class="mt-2 text-sm text-studio-400 leading-relaxed">{item.description}</p>
              </div>
            </div>
          </div>
        ))}
      </div>

      <!-- Education -->
      <div class="mt-16">
        <div class="flex items-center gap-3 mb-8">
          <span class="annotation">education.log</span>
          <div class="flex-1 h-px bg-accent-blue/10" />
        </div>

        <div class="track-card rounded-lg p-5">
          <div class="flex items-start gap-4">
            <div class="flex flex-col items-center pt-1">
              <div class="w-2 h-2 rounded-full bg-accent-blue" />
            </div>
            <div>
              <h3 class="font-display text-base font-semibold text-studio-100">M.Sc. in Data Science</h3>
              <p class="font-mono text-xs text-accent-cyan mt-0.5">University of Helsinki</p>
              <p class="mt-2 text-sm text-studio-400">
                Thesis on fine-tuning BERT for domain-specific NLP tasks.
              </p>
              <a
                href="https://helda-test-22.hulib.helsinki.fi/server/api/core/bitstreams/18965213-27ba-4e04-bb80-3c165b75de99/content"
                target="_blank"
                rel="noopener noreferrer"
                class="inline-block mt-2 font-mono text-xs text-accent-blue hover:text-accent-cyan transition-colors"
              >
                read_thesis() &rarr;
              </a>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
