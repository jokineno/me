---
import BaseLayout from "../layouts/BaseLayout.astro";
import ParticleNetwork from "../components/ParticleNetwork.astro";
import SocialLinks from "../components/SocialLinks.astro";
---

<BaseLayout title="Olli Jokinen — Home">
  <section class="relative flex min-h-[calc(100vh-4rem)] flex-col items-center justify-center px-6 overflow-hidden">
    <!-- Three.js particle network background -->
    <ParticleNetwork />

    <!-- Content -->
    <div class="relative z-10 flex max-w-2xl flex-col items-center text-center">
      <!-- Avatar -->
      <div class="mb-6 flex h-20 w-20 items-center justify-center rounded-full bg-gradient-to-br from-iso-400 via-iso-500 to-iso-600 iso-shadow">
        <span class="font-display text-2xl font-bold text-white">OJ</span>
      </div>

      <!-- Name -->
      <h1 class="font-display text-4xl font-bold tracking-tight text-iso-800 sm:text-5xl md:text-6xl">
        Olli Jokinen
      </h1>
      <div class="mt-2 h-1.5 w-24 rounded-full bg-gradient-to-r from-iso-400 via-iso-500 to-iso-600 iso-shadow" />

      <!-- Bio -->
      <p class="mt-8 max-w-lg text-lg leading-relaxed text-slate-500">
        Developer and engineer scaling European startups into global products.
        I build across the full stack — from data platforms and AI-driven
        applications to LLM fine-tuning and frontend. Recognized by Deloitte
        Tech Fast 50 and the Google Cloud Customer Award.
      </p>

      <!-- Social links -->
      <div class="mt-10">
        <SocialLinks />
      </div>
    </div>

    <!-- Career Timeline -->
    <div class="relative z-10 mt-24 w-full max-w-2xl px-4">
      <h2 class="font-display text-2xl font-bold text-iso-800 text-center mb-12">Career</h2>
      <div class="relative">
        <!-- Vertical line -->
        <div class="absolute left-4 md:left-1/2 top-0 bottom-0 w-0.5 bg-iso-200 -translate-x-1/2" aria-hidden="true" />

        {[
          { year: "2025 —", role: "Founding Engineer", company: "Zero.inc", description: "Building the next generation of autonomous GTM." },
          { year: "2024 — 2025", role: "Lead Data Engineer", company: "RELEX Solutions", description: "Designing and implementing data platforms and data products at scale." },
          { year: "2020 — 2024", role: "Data Scientist → Senior Data Engineer, Cloud Architect & Onboarding Tech Lead", company: "Snowfox.AI", description: "Scaled revenue 15x from 0.2M to 3M. #3 developer, #7 employee. Google Cloud Customer Award 2023, Deloitte Tech Fast 50 (2024 & 2025)." },
          { year: "2014 — 2020", role: "Developer & Data Scientist", company: "Self-Employed", description: "Freelance consulting, web development, and data science for startups." },
        ].map((item, i) => (
          <div class:list={["relative flex items-start mb-8 last:mb-0", i % 2 === 0 ? "md:flex-row-reverse" : ""]}>
            <!-- Dot -->
            <div class="absolute left-4 md:left-1/2 w-3 h-3 bg-iso-500 rounded-sm rotate-45 -translate-x-1/2 mt-1.5 z-10 border-2 border-white" />

            <!-- Card -->
            <div class:list={["ml-10 md:ml-0 md:w-[calc(50%-2rem)]", i % 2 === 0 ? "md:mr-auto md:pr-0 md:pl-0" : "md:ml-auto"]}>
              <div class="bg-white border-2 border-iso-200 rounded-xl p-5 iso-shadow">
                <span class="text-xs font-semibold uppercase tracking-wider text-iso-500">{item.year}</span>
                <h3 class="mt-1 font-display text-lg font-semibold text-slate-800">{item.role}</h3>
                <p class="text-sm font-medium text-iso-600">{item.company}</p>
                <p class="mt-2 text-sm text-slate-500">{item.description}</p>
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>

    <!-- Education -->
    <div class="relative z-10 mt-20 w-full max-w-2xl px-4 mb-20">
      <h2 class="font-display text-2xl font-bold text-iso-800 text-center mb-8">Education</h2>
      <div class="bg-white border-2 border-iso-200 rounded-xl p-6 iso-shadow text-center">
        <h3 class="font-display text-lg font-semibold text-slate-800">M.Sc. in Data Science</h3>
        <p class="text-sm font-medium text-iso-600 mt-1">University of Helsinki</p>
        <p class="mt-3 text-sm text-slate-500">
          Thesis on fine-tuning BERT for domain-specific NLP tasks.
        </p>
        <a
          href="https://helda-test-22.hulib.helsinki.fi/server/api/core/bitstreams/18965213-27ba-4e04-bb80-3c165b75de99/content"
          target="_blank"
          rel="noopener noreferrer"
          class="inline-block mt-3 text-sm font-medium text-iso-600 hover:text-iso-800 transition-colors"
        >
          Read thesis &rarr;
        </a>
      </div>
    </div>
  </section>
</BaseLayout>
