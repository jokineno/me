---
import BaseLayout from "../layouts/BaseLayout.astro";
import GradientBlob from "../components/GradientBlob.astro";
import SocialLinks from "../components/SocialLinks.astro";
---

<BaseLayout title="jokineno — Home">
  <section class="relative flex min-h-[calc(100vh-4rem)] flex-col items-center justify-center px-6">
    <!-- Decorative blobs -->
    <GradientBlob
      class="animate-float -top-20 -left-32 h-72 w-72 md:h-96 md:w-96"
      colors="from-brand-fuchsia via-brand-violet to-brand-cyan"
    />
    <GradientBlob
      class="animate-float-delayed -bottom-20 -right-32 h-64 w-64 md:h-80 md:w-80"
      colors="from-brand-amber via-brand-rose to-brand-fuchsia"
    />
    <GradientBlob
      class="animate-float top-1/3 right-1/4 h-48 w-48"
      colors="from-brand-emerald via-brand-cyan to-brand-violet"
    />

    <!-- Content -->
    <div class="relative z-10 flex max-w-2xl flex-col items-center text-center">
      <!-- Avatar placeholder -->
      <div class="mb-8 flex h-28 w-28 items-center justify-center rounded-full bg-gradient-to-br from-brand-fuchsia via-brand-cyan to-brand-amber p-[3px]">
        <div class="flex h-full w-full items-center justify-center rounded-full bg-gray-950">
          <span class="font-display text-3xl font-bold text-white">J</span>
        </div>
      </div>

      <!-- Name with gradient -->
      <h1 class="font-display text-4xl font-bold tracking-tight sm:text-5xl md:text-6xl">
        <span class="animate-gradient-text bg-gradient-to-r from-brand-fuchsia via-brand-cyan to-brand-amber bg-clip-text text-transparent">
          jokineno
        </span>
      </h1>

      <!-- Bio -->
      <p class="mt-6 max-w-md text-lg leading-relaxed text-gray-400">
        Developer, builder, and maker of things on the internet.
        Passionate about clean code and creative solutions.
      </p>

      <!-- Social links -->
      <div class="mt-10">
        <SocialLinks />
      </div>
    </div>
  </section>
</BaseLayout>
