---
const pathname = Astro.url.pathname;
const links = [
  { href: "/", label: "Home" },
  { href: "/thoughts", label: "Thoughts" },
  { href: "/blog", label: "Blog" },
];
---

<header class="fixed top-0 left-0 right-0 z-50 bg-studio-900/80 backdrop-blur-md border-b border-accent-blue/10">
  <nav class="mx-auto flex max-w-4xl items-center justify-between px-6 py-4">
    <a href="/" class="font-mono text-sm font-medium text-accent-blue tracking-wider flex items-center gap-2">
      <span class="inline-block w-2 h-2 rounded-full bg-accent-blue glow-blue" />
      OJ
    </a>
    <div class="flex gap-1">
      {links.map((link) => (
        <a
          href={link.href}
          class:list={[
            "font-mono text-xs tracking-wider px-4 py-2 rounded transition-all duration-200",
            pathname === link.href
              ? "text-accent-blue bg-accent-blue/10"
              : "text-studio-400 hover:text-accent-blue hover:bg-accent-blue/5",
          ]}
        >
          {link.label}
        </a>
      ))}
    </div>
  </nav>
</header>
