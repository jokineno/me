---
const pathname = Astro.url.pathname;
const links = [
  { href: "/", label: "Home" },
  { href: "/blog", label: "Blog" },
];
---

<header class="fixed top-0 left-0 right-0 z-50 bg-white/70 backdrop-blur-md border-b border-iso-200">
  <nav class="mx-auto flex max-w-4xl items-center justify-between px-6 py-4">
    <a href="/" class="font-display text-lg font-bold text-iso-700 flex items-center gap-2">
      <svg width="20" height="20" viewBox="0 0 20 20" class="inline-block">
        <polygon points="10,0 20,5 20,15 10,20 0,15 0,5" fill="#3b82f6" opacity="0.8"/>
        <polygon points="10,0 20,5 10,10 0,5" fill="#93c5fd"/>
        <polygon points="10,10 20,5 20,15 10,20" fill="#60a5fa"/>
        <polygon points="10,10 0,5 0,15 10,20" fill="#2563eb"/>
      </svg>
      jokineno
    </a>
    <div class="flex gap-1">
      {links.map((link) => (
        <a
          href={link.href}
          class:list={[
            "text-sm font-medium px-4 py-2 rounded-lg transition-all duration-200",
            pathname === link.href
              ? "bg-iso-600 text-white iso-shadow"
              : "text-slate-500 hover:text-iso-700 hover:bg-iso-100",
          ]}
        >
          {link.label}
        </a>
      ))}
    </div>
  </nav>
</header>
