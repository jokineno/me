---
---

<canvas id="waveform-canvas" class="absolute inset-0 w-full h-full" aria-hidden="true"></canvas>

<script>
  import * as THREE from "three";

  function init() {
    const canvas = document.getElementById("waveform-canvas") as HTMLCanvasElement;
    if (!canvas) return;

    const renderer = new THREE.WebGLRenderer({ canvas, alpha: true, antialias: true });
    renderer.setPixelRatio(Math.min(window.devicePixelRatio, 2));

    const scene = new THREE.Scene();
    const camera = new THREE.OrthographicCamera(-1, 1, 1, -1, 0.1, 10);
    camera.position.z = 1;

    // Create multiple waveform lines at different vertical positions
    const WAVE_COUNT = 5;
    const POINTS_PER_WAVE = 200;
    const waves: { mesh: THREE.Line; phase: number; speed: number; amplitude: number; frequency: number; y: number; color: THREE.Color }[] = [];

    const waveConfigs = [
      { y: 0.0, amplitude: 0.08, frequency: 2.0, speed: 0.8, color: new THREE.Color(0x38bdf8), opacity: 0.6 },
      { y: 0.15, amplitude: 0.05, frequency: 3.0, speed: 1.2, color: new THREE.Color(0x22d3ee), opacity: 0.3 },
      { y: -0.15, amplitude: 0.06, frequency: 2.5, speed: 0.6, color: new THREE.Color(0x38bdf8), opacity: 0.25 },
      { y: 0.3, amplitude: 0.03, frequency: 4.0, speed: 1.5, color: new THREE.Color(0xfbbf24), opacity: 0.15 },
      { y: -0.3, amplitude: 0.04, frequency: 3.5, speed: 1.0, color: new THREE.Color(0x4ade80), opacity: 0.12 },
    ];

    for (let w = 0; w < WAVE_COUNT; w++) {
      const config = waveConfigs[w];
      const geometry = new THREE.BufferGeometry();
      const positions = new Float32Array(POINTS_PER_WAVE * 3);

      for (let i = 0; i < POINTS_PER_WAVE; i++) {
        positions[i * 3] = (i / (POINTS_PER_WAVE - 1)) * 2 - 1;
        positions[i * 3 + 1] = config.y;
        positions[i * 3 + 2] = 0;
      }

      geometry.setAttribute("position", new THREE.BufferAttribute(positions, 3));

      const material = new THREE.LineBasicMaterial({
        color: config.color,
        transparent: true,
        opacity: config.opacity,
      });

      const line = new THREE.Line(geometry, material);
      scene.add(line);

      waves.push({
        mesh: line,
        phase: Math.random() * Math.PI * 2,
        speed: config.speed,
        amplitude: config.amplitude,
        frequency: config.frequency,
        y: config.y,
        color: config.color,
      });
    }

    // Mouse tracking for wave distortion
    let mouseX = 0.5;
    let mouseY = 0.5;

    function onMouseMove(e: MouseEvent) {
      const rect = canvas.getBoundingClientRect();
      mouseX = (e.clientX - rect.left) / rect.width;
      mouseY = (e.clientY - rect.top) / rect.height;
    }

    canvas.addEventListener("mousemove", onMouseMove);

    // Resize
    function resize() {
      const parent = canvas.parentElement;
      if (!parent) return;
      const w = parent.clientWidth;
      const h = parent.clientHeight;
      renderer.setSize(w, h);
      const aspect = w / h;
      camera.left = -aspect;
      camera.right = aspect;
      camera.updateProjectionMatrix();
    }

    resize();
    window.addEventListener("resize", resize);

    // Animation
    let time = 0;

    function animate() {
      requestAnimationFrame(animate);
      time += 0.016;

      for (const wave of waves) {
        const positions = wave.mesh.geometry.attributes.position.array as Float32Array;

        for (let i = 0; i < POINTS_PER_WAVE; i++) {
          const x = i / (POINTS_PER_WAVE - 1);

          // Base sine wave
          let y = Math.sin(x * Math.PI * wave.frequency + time * wave.speed + wave.phase) * wave.amplitude;

          // Add harmonics for organic feel
          y += Math.sin(x * Math.PI * wave.frequency * 2.3 + time * wave.speed * 0.7) * wave.amplitude * 0.3;
          y += Math.sin(x * Math.PI * wave.frequency * 0.5 + time * wave.speed * 1.3) * wave.amplitude * 0.2;

          // Mouse influence — waves bulge near cursor
          const distToMouse = Math.abs(x - mouseX);
          if (distToMouse < 0.2) {
            const influence = (1 - distToMouse / 0.2) * 0.04;
            y += Math.sin(time * 3) * influence * (1 - Math.abs(mouseY - 0.5) * 2);
          }

          // Fade edges
          const edgeFade = Math.min(x * 5, (1 - x) * 5, 1);
          y *= edgeFade;

          positions[i * 3 + 1] = wave.y + y;
        }

        wave.mesh.geometry.attributes.position.needsUpdate = true;
      }

      renderer.render(scene, camera);
    }

    animate();

    // Cleanup on View Transitions
    document.addEventListener("astro:before-swap", () => {
      renderer.dispose();
      window.removeEventListener("resize", resize);
      canvas.removeEventListener("mousemove", onMouseMove);
    });
  }

  init();
  document.addEventListener("astro:after-swap", init);
</script>
